---
// Static app shell. Header/footer are server-rendered into the static HTML;
// the <main id="app"> is filled by the client router (scripts/app.ts).
// index/search/omnisearch/programmes and 404.html all render this same shell.
// Social scrapers don't run JS, so the SEO/OG meta below is the static baseline
// for every shared link (app.ts refreshes title/canonical/og:url client-side per
// view; per-show OG cards would need pre-rendering — a future step).
import "../styles/styles.css";

interface Props {
  title?: string;
  description?: string;
  path?: string;
}
const SITE = "https://rozhlas.org";
const DEFAULT_DESC =
  "Prohledávejte a poslouchejte archiv mluveného slova Českého rozhlasu — četba na pokračování, povídky, rozhlasové hry, pohádky a dokumenty. Univerzální vyhledávání i v přepisech namluvených pořadů.";
const { title, description, path = "/" } = Astro.props;
const fullTitle = title
  ? `${title} — rozhlas.org`
  : "rozhlas.org — archiv četby a mluveného slova Českého rozhlasu";
const desc = description ?? DEFAULT_DESC;
const canonical = SITE + path;
const ogImage = `${SITE}/og.png`;
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${SITE}/#website`,
      url: `${SITE}/`,
      name: "rozhlas.org",
      description: DEFAULT_DESC,
      inLanguage: "cs",
      potentialAction: {
        "@type": "SearchAction",
        target: { "@type": "EntryPoint", urlTemplate: `${SITE}/omnisearch?q={search_term_string}` },
        "query-input": "required name=search_term_string",
      },
    },
    {
      "@type": "Organization",
      "@id": `${SITE}/#org`,
      name: "rozhlas.org",
      url: `${SITE}/`,
      logo: ogImage,
    },
  ],
};
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#ffffff" />
    {/* Apply the saved theme + theme-color BEFORE paint to avoid a light flash. */}
    <script is:inline>
      (function () {
        try {
          var p = localStorage.getItem("rozhlas:theme");
          var explicit = p === "dark" || p === "light";
          if (explicit) document.documentElement.dataset.theme = p;
          var dark = p === "dark" || (!explicit && matchMedia("(prefers-color-scheme: dark)").matches);
          var m = document.querySelector('meta[name="theme-color"]');
          if (m) m.setAttribute("content", dark ? "#161616" : "#ffffff");
        } catch (e) {}
      })();
    </script>
    <meta name="robots" content="index, follow" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Installable PWA (no install prompt; the browser offers it natively). -->
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="rozhlas.org" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="rozhlas.org" />
    <meta property="og:locale" content="cs_CZ" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Saira+Condensed:wght@600;700;800;900&family=Saira:wght@400;500;600&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="has-player">
    <header class="site-header">
      <a class="site-header__brand" href="/">rozhlas<span class="accent">.org</span></a>
      <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Přepnout motiv" title="Motiv">◐</button>
      <div class="site-nav-wrap">
        <nav class="site-nav" id="site-nav">
          <a href="/">Pořady</a>
          <a href="/programmes">Kategorie</a>
          <a href="/historie">Naposledy</a>
          <a href="/oblibene">Oblíbené</a>
          <a href="/stazene">Stažené</a>
          <a href="/transcripts">V přepisech</a>
        </nav>
      </div>
    </header>
    <main class="site-main" id="app" aria-busy="true">
      <p class="notice">Načítám…</p>
      <noscript>Tento web vyžaduje JavaScript pro zobrazení obsahu.</noscript>
    </main>
    <footer class="site-footer">
      <p>Archiv pořadů Českého rozhlasu · audio přes IPFS · zaměřeno na četbu a čtení.</p>
      <p class="site-footer__links">
        <a href="https://github.com/rozhlas-org/rozhlas.org" rel="noopener me" target="_blank">GitHub</a>
        <span aria-hidden="true">·</span>
        <a href="https://www.mujrozhlas.cz/" rel="noopener" target="_blank">mujRozhlas</a>
        <!-- Revealed by pwa.ts only when the browser offers installation. -->
        <button id="install-app" class="site-footer__install" type="button" hidden>⤓ Instalovat aplikaci</button>
      </p>
    </footer>

    <!-- Persistent player: lives in the shell (outside #app) so SPA navigation
         never stops playback. Filled/controlled by scripts/player.ts. -->
    <div id="player" class="player-bar" aria-label="Přehrávač">
      <!-- Row 1: cover + (now-label + time on one line) / title. Time sits top-right,
           above the title, without shifting it. Always on screen. -->
      <div class="player-bar__row player-bar__row--meta">
        <div id="player-art" class="player-bar__art player-bar__art--empty" aria-hidden="true"></div>
        <div class="player-bar__meta">
          <div class="player-bar__metahead">
            <div id="player-now" class="player-bar__now">Přehrávač</div>
            <div id="player-time" class="player-bar__time">0:00 / 0:00</div>
          </div>
          <a id="player-title" class="player-bar__title player-bar__title--idle">Nic nehraje</a>
        </div>
      </div>
      <!-- Row 2: full-width scrubber, directly under the title (above the controls). -->
      <div class="player-bar__row player-bar__row--seek">
        <input id="player-seek" class="player-bar__seek" type="range" min="0" max="1000" value="0" aria-label="Pozice ve stopě" disabled />
      </div>
      <!-- Row 3: centered transport [prev −15 play +15 next], queue button at the right.
           Disabled in static markup; player.ts enables once a track/queue is ready. -->
      <div class="player-bar__row player-bar__row--controls">
        <button
          id="player-transcript-toggle"
          class="player-bar__btn player-bar__transcript"
          type="button"
          aria-label="Přepis"
          aria-expanded="false"
          aria-controls="player-transcript"
          disabled
        >CC</button>
        <div class="player-bar__transport">
          <button id="player-prev" class="player-bar__btn player-bar__nav" type="button" aria-label="Předchozí" disabled>⏮</button>
          <button id="player-back15" class="player-bar__btn player-bar__nav player-bar__skip" type="button" aria-label="Zpět o 15 sekund" title="Zpět o 15 s" disabled>
            <svg class="player-bar__skipicon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/><text x="12.5" y="15.5" text-anchor="middle" font-size="8" font-weight="700" stroke="none" fill="currentColor" font-family="monospace">15</text></svg>
          </button>
          <button id="player-toggle" class="player-bar__btn player-bar__toggle" type="button" aria-label="Přehrát" disabled>▶</button>
          <button id="player-fwd15" class="player-bar__btn player-bar__nav player-bar__skip" type="button" aria-label="Vpřed o 15 sekund" title="Vpřed o 15 s" disabled>
            <svg class="player-bar__skipicon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/><text x="11.5" y="15.5" text-anchor="middle" font-size="8" font-weight="700" stroke="none" fill="currentColor" font-family="monospace">15</text></svg>
          </button>
          <button id="player-next" class="player-bar__btn player-bar__nav" type="button" aria-label="Další" disabled>⏭</button>
        </div>
        <button
          id="player-queue-toggle"
          class="player-bar__btn player-bar__queue"
          type="button"
          aria-label="Fronta"
          aria-expanded="false"
          aria-controls="player-queue"
        >☰<span id="player-queue-badge" class="player-bar__badge" hidden>0</span></button>
      </div>
      <audio id="player-audio" preload="none"></audio>
      <!-- Queue panel ("Fronta"), rendered by scripts/player.ts; lives in the shell so navigation can't destroy it. -->
      <div id="player-queue" class="queue-panel" hidden role="region" aria-label="Fronta"></div>
      <!-- Live transcript panel ("Přepis") — pops above the bar, follows playback. -->
      <div id="player-transcript" class="transcript-pop" hidden role="region" aria-label="Přepis"></div>
    </div>

    <script>
      import "../scripts/app.ts";
    </script>
  </body>
</html>
