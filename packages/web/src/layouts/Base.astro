---
// Static app shell. Header/footer are server-rendered into the static HTML;
// the <main id="app"> is filled by the client router (scripts/app.ts).
// index/search/omnisearch/programmes and 404.html all render this same shell.
import "../styles/styles.css";
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>rozhlas.org</title>
    <meta name="description" content="Archiv pořadů Českého rozhlasu — zaměřeno na četbu a čtení. Audio přes IPFS." />
    <meta name="theme-color" content="#ffffff" />
    {/* Apply the saved theme + theme-color BEFORE paint to avoid a light flash. */}
    <script is:inline>
      (function () {
        try {
          var p = localStorage.getItem("rozhlas:theme");
          var explicit = p === "dark" || p === "light";
          if (explicit) document.documentElement.dataset.theme = p;
          var dark = p === "dark" || (!explicit && matchMedia("(prefers-color-scheme: dark)").matches);
          var m = document.querySelector('meta[name="theme-color"]');
          if (m) m.setAttribute("content", dark ? "#161616" : "#ffffff");
        } catch (e) {}
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Saira+Condensed:wght@600;700;800;900&family=Saira:wght@400;500;600&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="has-player">
    <header class="site-header">
      <a class="site-header__brand" href="/">rozhlas<span class="accent">.org</span></a>
      <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Přepnout motiv" title="Motiv">◐</button>
      <div class="site-nav-wrap">
        <nav class="site-nav" id="site-nav">
          <a href="/">Pořady</a>
          <a href="/programmes">Kategorie</a>
          <a href="/historie">Naposledy</a>
          <a href="/oblibene">Oblíbené</a>
          <a href="/transcripts">V přepisech</a>
        </nav>
      </div>
    </header>
    <main class="site-main" id="app" aria-busy="true">
      <p class="notice">Načítám…</p>
      <noscript>Tento web vyžaduje JavaScript pro zobrazení obsahu.</noscript>
    </main>
    <footer class="site-footer">
      <p>Archiv pořadů Českého rozhlasu · audio přes IPFS · zaměřeno na četbu a čtení.</p>
    </footer>

    <!-- Persistent player: lives in the shell (outside #app) so SPA navigation
         never stops playback. Filled/controlled by scripts/player.ts. -->
    <div id="player" class="player-bar" aria-label="Přehrávač">
      <!-- Row 1: cover + now-playing label + title, full width. Always on screen;
           player.ts shows a placeholder + dimmed transport when nothing's loaded. -->
      <div class="player-bar__row player-bar__row--meta">
        <div id="player-art" class="player-bar__art player-bar__art--empty" aria-hidden="true"></div>
        <div class="player-bar__meta">
          <div id="player-now" class="player-bar__now">Přehrávač</div>
          <a id="player-title" class="player-bar__title player-bar__title--idle">Nic nehraje</a>
        </div>
      </div>
      <!-- Row 2: transport (prev/play/next) + seek + time + queue. Disabled in the
           static markup; player.ts enables them once a track (or queue) is ready. -->
      <div class="player-bar__row player-bar__row--controls">
        <button id="player-prev" class="player-bar__btn player-bar__nav" type="button" aria-label="Předchozí" disabled>⏮</button>
        <button id="player-toggle" class="player-bar__btn player-bar__toggle" type="button" aria-label="Přehrát" disabled>▶</button>
        <button id="player-next" class="player-bar__btn player-bar__nav" type="button" aria-label="Další" disabled>⏭</button>
        <input id="player-seek" class="player-bar__seek" type="range" min="0" max="1000" value="0" aria-label="Pozice ve stopě" disabled />
        <div id="player-time" class="player-bar__time">0:00 / 0:00</div>
        <button
          id="player-queue-toggle"
          class="player-bar__btn player-bar__queue"
          type="button"
          aria-label="Fronta"
          aria-expanded="false"
          aria-controls="player-queue"
        >☰<span id="player-queue-badge" class="player-bar__badge" hidden>0</span></button>
      </div>
      <audio id="player-audio" preload="none"></audio>
      <!-- Queue panel ("Fronta"), rendered by scripts/player.ts; lives in the shell so navigation can't destroy it. -->
      <div id="player-queue" class="queue-panel" hidden role="region" aria-label="Fronta"></div>
    </div>

    <script>
      import "../scripts/app.ts";
    </script>
  </body>
</html>
