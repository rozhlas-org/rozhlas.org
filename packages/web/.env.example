# Build-time API origin the static frontend calls (no trailing slash).
# Production default (baked in if unset): https://api.rozhlas.org
# For local dev against a local API: http://localhost:3000
PUBLIC_API_BASE=https://api.rozhlas.org
# Playback gate (optional): SHA-256 hex of the unlock password. When set (64 hex chars),
# the built site hides all playback until unlocked at /auth. Unset/empty → gate off (dev).
# e.g. printf '123456' | sha256sum
PUBLIC_AUTH_HASH=
