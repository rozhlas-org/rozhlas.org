# rozhlas.org reverse proxy — TLS via Let's Encrypt using the Cloudflare DNS-01
# challenge (works while records are proxied/orange-cloud). The Cloudflare API
# token is read from the environment (CLOUDFLARE_API_TOKEN), injected by systemd.
#
# Routing:
#   api.rozhlas.org   -> Hono JSON API + /healthz            (127.0.0.1:3000)
#   admin.rozhlas.org -> Bull Board, login-gated; / -> /admin/jobs (127.0.0.1:3000)
#   ipfs.rozhlas.org  -> self-hosted IPFS Kubo gateway       (127.0.0.1:8080)
#
# The frontend (rozhlas.org) is NOT served here — it's on GitHub Pages.

{
	email mail@janfabian.cz
}

(cf_tls) {
	tls {
		dns cloudflare {env.CLOUDFLARE_API_TOKEN}
		resolvers 1.1.1.1 1.0.0.1
	}
}

api.rozhlas.org {
	import cf_tls
	encode zstd gzip
	reverse_proxy 127.0.0.1:3000
}

admin.rozhlas.org {
	import cf_tls
	encode zstd gzip
	# Land visitors on the operator dashboard; the app redirects to login if needed.
	@root path /
	redir @root /admin 302
	reverse_proxy 127.0.0.1:3000
}

ipfs.rozhlas.org {
	import cf_tls
	encode gzip
	# Gateway serves immutable content-addressed data; cache aggressively at the edge.
	header /ipfs/* Cache-Control "public, max-age=31536000, immutable"
	reverse_proxy 127.0.0.1:8080
}
