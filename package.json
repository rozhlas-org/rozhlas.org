{
  "name": "rozhlas.org",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "db:generate": "bun run --cwd packages/core db:generate",
    "db:migrate": "bun run --cwd packages/core db:migrate",
    "api": "bun run --cwd packages/api dev",
    "worker": "bun run --cwd packages/worker dev",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^5.6.3"
  },
  "overrides": {
    "ioredis": "5.10.1"
  },
  "dependencies": {
    "sqlite-vec": "^0.1.9"
  }
}
