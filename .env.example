# Copy to .env and fill in. .env is gitignored.

# --- App ---
NODE_ENV=development
LOG_LEVEL=info
API_PORT=3000

# Where the SQLite DB file lives (relative paths are resolved from repo root)
DATABASE_PATH=./data/rozhlas.db

# --- Redis (BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- IPFS (self-hosted Kubo) ---
# Kubo RPC API (add/pin) and public gateway (streaming by CID).
# In production set IPFS_GATEWAY_URL to the PUBLIC gateway so the API hands the
# frontend playable URLs, e.g. https://ipfs.rozhlas.org
IPFS_API_URL=http://localhost:5001
IPFS_GATEWAY_URL=http://localhost:8080

# --- Admin dashboard ---
# Bull Board is mounted here on the api/web service
BULL_BOARD_PATH=/admin/jobs
# Login+session gate for /admin. Admin is LOCKED (503) until BOTH are set.
ADMIN_PASSWORD=
# Random string signing the admin session cookie (e.g. `openssl rand -hex 32`).
SESSION_SECRET=
SESSION_TTL_HOURS=168

# --- CORS ---
# Browser origins allowed to call the JSON API (the static frontend on Pages).
# Localhost is always allowed for local dev.
CORS_ORIGINS=https://rozhlas.org,https://www.rozhlas.org

# --- AI / omnisearch (Phase 4) ---
# Without VOYAGE_API_KEY, a deterministic local (lexical-only) embedder is used,
# so omnisearch works offline but isn't truly semantic. Set the key for real
# semantic search via Voyage AI.
# VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3.5
EMBEDDING_DIMS=1024
# Omnisearch intent parsing: "ollama" (local LLM, no API cost — default),
# "claude" (paid API), or "heuristic" (no LLM). Any provider error falls back to
# heuristic, so search never breaks.
INTENT_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
# Only used when INTENT_PROVIDER=claude:
# ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Secrets ---
GITHUB_TOKEN=
