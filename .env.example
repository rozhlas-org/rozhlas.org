# Copy to .env and fill in. .env is gitignored.

# --- App ---
NODE_ENV=development
LOG_LEVEL=info
API_PORT=3000

# Where the SQLite DB file lives (relative paths are resolved from repo root)
DATABASE_PATH=./data/rozhlas.db

# --- Redis (BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- IPFS (self-hosted Kubo) ---
# Kubo RPC API (add/pin) and public gateway (streaming by CID)
IPFS_API_URL=http://localhost:5001
IPFS_GATEWAY_URL=http://localhost:8080

# --- Admin dashboard ---
# Bull Board is mounted here on the api/web service
BULL_BOARD_PATH=/admin/jobs

# --- AI / omnisearch (Phase 4) ---
# Without VOYAGE_API_KEY, a deterministic local (lexical-only) embedder is used,
# so omnisearch works offline but isn't truly semantic. Set the key for real
# semantic search via Voyage AI.
# VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3.5
EMBEDDING_DIMS=1024
# Without ANTHROPIC_API_KEY, omnisearch intent parsing falls back to a heuristic.
# ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Secrets ---
GITHUB_TOKEN=
