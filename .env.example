# Copy to .env and fill in. .env is gitignored.

# --- App ---
NODE_ENV=development
LOG_LEVEL=info
API_PORT=3000

# Where the SQLite DB file lives (relative paths are resolved from repo root)
DATABASE_PATH=./data/rozhlas.db

# --- Redis (BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- IPFS (self-hosted Kubo) ---
# Kubo RPC API (add/pin) and public gateway (streaming by CID)
IPFS_API_URL=http://localhost:5001
IPFS_GATEWAY_URL=http://localhost:8080

# --- Admin dashboard ---
# Bull Board is mounted here on the api/web service
BULL_BOARD_PATH=/admin/jobs

# --- Secrets (used in later phases) ---
GITHUB_TOKEN=
# VOYAGE_API_KEY=
# ANTHROPIC_API_KEY=
